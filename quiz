# --- 3. QUESTION AND ANSWER GENERATION CORE ---

# Target entities suitable for good quiz questions (NER Labels)
TARGET_ENTS = ["PERSON", "ORG", "DATE", "GPE", "PRODUCT", "EVENT"]

def generate_quiz_pairs(text, num_options=4):
    """
    Processes text using spaCy NER to find key concepts and generates MCQs.
    """
    doc = nlp(text)
    sentences = sent_tokenize(text) 
    all_questions = []
    
    # Create a pool of all potential answers (entities) for distractors
    all_entities = [
        ent.text.strip() for ent in doc.ents 
        if ent.label_ in TARGET_ENTS and len(ent.text.split()) > 1 
        or ent.label_ in ["PERSON", "DATE"]
    ]
    
    distractor_pool = sorted(list(set(all_entities)), key=len, reverse=True)
    
    for sent in sentences:
        sent_doc = nlp(sent)
        
        key_entities = [ent for ent in sent_doc.ents if ent.label_ in TARGET_ENTS]
        
        if key_entities:
            answer_ent = max(key_entities, key=lambda ent: len(ent.text))
            answer_text = answer_ent.text.strip()
            
            # --- 1. Create the Question Stem (Fill-in-the-Blank) ---
            
            pattern = re.compile(r'\b' + re.escape(answer_text) + r'\b', re.IGNORECASE)
            question_stem = pattern.sub("_________.", sent).strip()
            
            question_stem = re.sub(r'[\s\.]+$', '', question_stem).capitalize()
            
            # --- 2. Generate Distractors for MCQ ---
            
            incorrect_options = [
                d for d in distractor_pool 
                if d.lower() != answer_text.lower() and d.lower() not in question_stem.lower()
            ]
            
            if len(incorrect_options) >= (num_options - 1):
                distractors = random.sample(incorrect_options, num_options - 1)
            else:
                remaining_needed = num_options - 1 - len(incorrect_options)
                
                filler_candidates = [
                    d for d in distractor_pool 
                    if d.lower() not in [o.lower() for o in incorrect_options] and d.lower() != answer_text.lower()
                ]
                
                if len(filler_candidates) >= remaining_needed:
                    distractors = incorrect_options + random.sample(filler_candidates, remaining_needed)
                else:
                    distractors = incorrect_options + [f"Placeholder {i}" for i in range(remaining_needed)]
            
            options = distractors + [answer_text]
            random.shuffle(options)
            
            all_questions.append({
                "question": f"{question_stem}?",
                "answer": answer_text,
                "options": options
            })
            
    return all_questions


# --- 4. OUTPUT FORMATTING ---

def format_quiz(quiz_data):
    """Prints the generated quiz in a readable format."""
    print("\n" + "="*60)
    print("                 🧠 AI GENERATED QUIZ 🧠")
    print("="*60)

    for i, q in enumerate(quiz_data, 1):
        print(f"\n--- Question {i} (Multiple Choice) ---")
        print(f"Q: {q['question']}")
        
        option_letters = ['A', 'B', 'C', 'D', 'E']
        for idx, option in enumerate(q['options']):
            if idx < len(option_letters):
                print(f"   {option_letters[idx]}. {option}")
            else:
                break
        
        try:
            correct_letter = option_letters[q['options'].index(q['answer'])]
        except ValueError:
             correct_letter = "N/A (Answer mismatch)"
             
        print(f"\n   -> Correct Answer: {q['answer']} ({correct_letter})")
        
    print("\n" + "="*60)
    print("Quiz Generation Complete.")
    print("="*60)


